# Steam Web API key — get one at https://steamcommunity.com/dev/apikey
STEAM_API_KEY=

# Server port (default 3000)
PORT=3000

# Humble Bundle affiliate tracking URL from Impact (optional)
# Get this from your Impact dashboard → Create a Link → copy the generated URL
HUMBLE_TRACKING_URL=

# Legacy: Humble Bundle partner ID (optional, used if HUMBLE_TRACKING_URL is not set)
HUMBLE_PARTNER_ID=
